---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { SITE_TITLE } from '../consts';
import '../styles/globals.css';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Instalaciones - ${SITE_TITLE}`} description="Conoce nuestras instalaciones de primer nivel en Cúcuta." />
	</head>
	<body class="antialiased">
		<Header />
		<main>
			<section class="section-padding bg-[#0b1020]">
				<div class="container-padding max-w-7xl mx-auto">
					<div class="text-center mb-16">
						<h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Nuestras Instalaciones</h1>
						<p class="text-lg text-white/70 max-w-2xl mx-auto">Espacios diseñados para tu comodidad y éxito profesional</p>
					</div>

					<div class="grid md:grid-cols-2 gap-8 mb-16">
						<div class="card-dark overflow-hidden group">
							<div class="aspect-video bg-gradient-to-br from-cyan-500/20 to-[#EA3D92]/20 flex items-center justify-center">
								<Icon name="monitor" size={48} class="text-cyan-400/50" />
							</div>
							<div class="p-6">
								<h3 class="text-xl font-bold text-white mb-2">Estudios de Transmisión</h3>
								<p class="text-white/70">Estudios privados equipados con iluminación profesional, cámaras HD y fondo green screen.</p>
							</div>
						</div>
						<div class="card-dark overflow-hidden group">
							<div class="aspect-video bg-gradient-to-br from-[#EA3D92]/20 to-cyan-500/20 flex items-center justify-center">
								<Icon name="heart" size={48} class="text-[#EA3D92]/50" />
							</div>
							<div class="p-6">
								<h3 class="text-xl font-bold text-white mb-2">Áreas de Descanso</h3>
								<p class="text-white/70">Espacios climatizados con áreas de descanso, cocina equipada y zona de relajación.</p>
							</div>
						</div>
						<div class="card-dark overflow-hidden group">
							<div class="aspect-video bg-gradient-to-br from-cyan-500/20 to-[#EA3D92]/20 flex items-center justify-center">
								<Icon name="shield" size={48} class="text-cyan-400/50" />
							</div>
							<div class="p-6">
								<h3 class="text-xl font-bold text-white mb-2">Seguridad 24/7</h3>
								<p class="text-white/70">Sistema de seguridad avanzado con cámaras, control de acceso y personal de seguridad.</p>
							</div>
						</div>
						<div class="card-dark overflow-hidden group">
							<div class="aspect-video bg-gradient-to-br from-[#EA3D92]/20 to-cyan-500/20 flex items-center justify-center">
								<Icon name="clock" size={48} class="text-[#EA3D92]/50" />
							</div>
							<div class="p-6">
								<h3 class="text-xl font-bold text-white mb-2">Disponibilidad 24/7</h3>
								<p class="text-white/70">Acceso a nuestras instalaciones las 24 horas del día, los 7 días de la semana con 3 turnos disponibles.</p>
							</div>
						</div>
					</div>

					<div class="card-dark p-8 md:p-12">
						<h2 class="text-2xl md:text-3xl font-bold text-white mb-6 text-center">Equipamiento</h2>
						<div class="grid md:grid-cols-3 gap-6">
							<div class="text-center">
								<div class="text-lg font-bold text-cyan-400 mb-1">Cámaras HD</div>
								<p class="text-white/60 text-sm">Profesionales 4K</p>
							</div>
							<div class="text-center">
								<div class="text-lg font-bold text-cyan-400 mb-1">Iluminación</div>
								<p class="text-white/60 text-sm">Profesional LED</p>
							</div>
							<div class="text-center">
								<div class="text-lg font-bold text-cyan-400 mb-1">Internet</div>
								<p class="text-white/60 text-sm">Fibra óptica dedicada</p>
							</div>
							<div class="text-center">
								<div class="text-lg font-bold text-cyan-400 mb-1">PC Gaming</div>
								<p class="text-white/60 text-sm">Alto rendimiento</p>
							</div>
							<div class="text-center">
								<div class="text-lg font-bold text-cyan-400 mb-1">Software</div>
								<p class="text-white/60 text-sm">Licencias incluidas</p>
							</div>
							<div class="text-center">
								<div class="text-lg font-bold text-cyan-400 mb-1">Sonido</div>
								<p class="text-white/60 text-sm">Micrófonos profesionales</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
