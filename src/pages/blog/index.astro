---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import { getPosts } from '../../lib/wordpress';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const POSTS_PER_PAGE = 9;
const allPosts = await getPosts();

const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);
const currentPage = Math.max(1, Math.min(totalPages, Number(Astro.url.searchParams.get('page')) || 1));
const start = (currentPage - 1) * POSTS_PER_PAGE;
const posts = allPosts.slice(start, start + POSTS_PER_PAGE);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="antialiased">
		<Header />
		<section class="section-padding bg-[#0b1020]">
			<div class="container-padding max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white/5 border border-[#2979FF]/30 mb-4">
						<Icon name="book-open" size={24} class="text-cyan-400" />
					</div>
					<h1 class="text-3xl md:text-4xl font-bold mb-4">Blog</h1>
					<p class="text-lg text-white/70 max-w-2xl mx-auto">
						Consejos, noticias y actualizaciones sobre la industria webcam
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{posts.map((post) => {
						const img = post._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
						const imgAlt = post._embedded?.["wp:featuredmedia"]?.[0]?.alt_text || "";
						const formatDate = (d: string) => new Date(d).toLocaleDateString("es-CO", { year: "numeric", month: "long", day: "numeric" });
						return (
							<article class="card-dark rounded-xl transition-all duration-300 overflow-hidden group">
								{img && (
									<div class="aspect-video overflow-hidden">
										<img src={img} alt={imgAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
									</div>
								)}
								<div class="p-6">
									<div class="flex items-center text-sm text-white/60 mb-3">
										<Icon name="calendar" size={16} class="mr-1 text-cyan-400" />
										{formatDate(post.date)}
									</div>
									<h2 class="text-lg font-bold text-white mb-3 line-clamp-2 group-hover:text-cyan-400 transition-colors">
										<a href={`/blog/${post.slug}`}>{post.title.rendered}</a>
									</h2>
									<div class="text-white/70 text-sm mb-4 line-clamp-3" set:html={post.excerpt.rendered} />
									<a href={`/blog/${post.slug}`} class="inline-flex items-center text-cyan-400 font-medium hover:text-cyan-300">
										Seguir Leyendo
										<Icon name="arrow-right" size={16} class="ml-1" />
									</a>
								</div>
							</article>
						);
					})}
				</div>

				{totalPages > 1 && (
					<div class="flex items-center justify-center gap-2 mt-12">
						{currentPage > 1 && (
							<a href={`/blog?page=${currentPage - 1}`} class="px-4 py-2 rounded-lg bg-white/5 border border-[#2979FF]/30 hover:bg-white/10 transition-colors">
								← Anterior
							</a>
						)}
						<span class="px-4 text-white/70">
							Página {currentPage} de {totalPages}
						</span>
						{currentPage < totalPages && (
							<a href={`/blog?page=${currentPage + 1}`} class="px-4 py-2 rounded-lg bg-white/5 border border-[#2979FF]/30 hover:bg-white/10 transition-colors">
								Siguiente →
							</a>
						)}
					</div>
				)}
			</div>
		</section>
		<Footer />
	</body>
</html>
