---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { SITE_TITLE } from '../consts';

const WHATSAPP_NUMBER = "573166004712";
const WHATSAPP_MESSAGE = "Hola, estoy interesada en conocer más sobre el estudio de modelaje webcam.";
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Contacto - Modelo Webcam en Cúcuta | SpyBlue Studio`} description="Contacta a SpyBlue Studio en Cúcuta. Agenda tu entrevista como modelo webcam por WhatsApp. Respuesta en menos de 24 horas. Consulta sin compromiso." />
	</head>
	<body class="antialiased">
		<Header />
		<main>
			<section class="section-padding site-section">
				<div class="container-padding max-w-7xl mx-auto">
					<div class="text-center mb-16">
						<h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contacto</h1>
						<p class="text-lg text-white/70 max-w-2xl mx-auto">Estamos aquí para resolver tus dudas y acompañarte en tu carrera</p>
					</div>

					<div class="grid md:grid-cols-2 gap-12">
						<div>
							<h2 class="text-2xl font-bold text-white mb-6">Escríbenos</h2>

							<div class="card-dark p-6 mb-6">
								<div class="flex items-start gap-4">
									<div class="w-12 h-12 rounded-xl bg-white/5 border border-[#2979FF]/30 flex items-center justify-center flex-shrink-0">
										<Icon name="phone" size={24} class="text-cyan-400" />
									</div>
									<div>
										<h3 class="font-semibold text-white mb-1">WhatsApp</h3>
										<a href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:text-cyan-300 transition-colors">+57 316 600 4712</a>
									</div>
								</div>
							</div>

							<div class="card-dark p-6 mb-6">
								<div class="flex items-start gap-4">
									<div class="w-12 h-12 rounded-xl bg-white/5 border border-[#2979FF]/30 flex items-center justify-center flex-shrink-0">
										<Icon name="mail" size={24} class="text-cyan-400" />
									</div>
									<div>
										<h3 class="font-semibold text-white mb-1">Email</h3>
										<a href="mailto:info@spyblue.co" class="text-cyan-400 hover:text-cyan-300 transition-colors">info@spyblue.co</a>
									</div>
								</div>
							</div>

							<div class="card-dark p-6 mb-6">
								<div class="flex items-start gap-4">
									<div class="w-12 h-12 rounded-xl bg-white/5 border border-[#2979FF]/30 flex items-center justify-center flex-shrink-0">
										<Icon name="map-pin" size={24} class="text-cyan-400" />
									</div>
									<div>
										<h3 class="font-semibold text-white mb-1">Ubicación</h3>
										<p class="text-white/70">Cúcuta, Norte de Santander, Colombia</p>
									</div>
								</div>
							</div>

						<div class="flex gap-4">
							<a href="https://www.instagram.com/spyblue.studio/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl bg-white/5 border border-[#2979FF]/30 flex items-center justify-center hover:bg-white/10 transition-colors" aria-label="Instagram">
								<Icon name="instagram" size={20} class="text-cyan-400" />
							</a>
							<a href="https://www.facebook.com/people/Spyblue-cucuta/100075925371638/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl bg-white/5 border border-[#2979FF]/30 flex items-center justify-center hover:bg-white/10 transition-colors" aria-label="Facebook">
								<Icon name="facebook" size={20} class="text-cyan-400" />
							</a>
							<a href="https://www.tiktok.com/@spyblue_studio" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl bg-white/5 border border-[#2979FF]/30 flex items-center justify-center hover:bg-white/10 transition-colors" aria-label="TikTok">
								<Icon name="tiktok" size={20} class="text-cyan-400" />
							</a>
						</div>
						</div>

						<div>
							<h2 class="text-2xl font-bold text-white mb-6">Agenda tu entrevista</h2>
							<div class="card-dark p-8">
								<p class="text-white/70 mb-6">Déjanos tus datos y te contactaremos para agendar una entrevista personalizada. Descubre cómo puedes empezar a generar ingresos con SpyBlue Studio.</p>
								<a
									href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg bg-gradient-to-r from-[#2979FF] to-[#EA3D92] text-white transition-all duration-300 hover:shadow-lg hover:shadow-[#EA3D92]/30 hover:-translate-y-0.5 w-full justify-center"
								>
									<Icon name="phone" size={20} />
									Contactar por WhatsApp
								</a>
								<p class="mt-4 text-white/40 text-sm text-center">Respuesta en menos de 24 horas &bull; Consulta sin compromiso</p>
							</div>
						</div>
				</div>

				<div class="mt-16">
					<div class="text-center mb-8">
						<h2 class="text-2xl font-bold text-white mb-2">Explora SpyBlue</h2>
						<p class="text-white/70">Descubre todo lo que tenemos para ofrecerte</p>
					</div>
					<div class="grid md:grid-cols-3 gap-6">
						<a href="/spyblue-cucuta" class="card-dark p-6 text-center group hover:border-cyan-400/30 transition-all">
							<h3 class="font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">Sobre Nosotros</h3>
							<p class="text-white/60 text-sm">Conoce SpyBlue Studio y nuestra misión</p>
						</a>
						<a href="/instalaciones-spyblue" class="card-dark p-6 text-center group hover:border-cyan-400/30 transition-all">
							<h3 class="font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">Instalaciones</h3>
							<p class="text-white/60 text-sm">Estudios y espacios de primer nivel</p>
						</a>
						<a href="/faq" class="card-dark p-6 text-center group hover:border-cyan-400/30 transition-all">
							<h3 class="font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">Preguntas Frecuentes</h3>
							<p class="text-white/60 text-sm">Resolvemos tus dudas</p>
						</a>
					</div>
				</div>
			</div>
		</section>
		</main>
		<Footer />
	</body>
</html>
