---
import Icon from './Icon.astro';

const WHATSAPP_NUMBER = "573166004712";

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/spyblue-cucuta" },
  { label: "Instalaciones", href: "/instalaciones-spyblue" },
  { label: "Trabajo WebCam", href: "/trabajo-webcam-en-cucuta" },
  { label: "FAQ", href: "/faq" },
  { label: "Contacto", href: "/modelo-webcam-en-cucuta" },
  { label: "Blog", href: "/blog-webcam" },
];

const legalLinks = [
  { label: "Política de Privacidad", href: "/privacidad" },
  { label: "Términos de Servicio", href: "/terminos" },
];

const today = new Date();
---

<footer class="site-footer">
  <div class="container-padding max-w-7xl mx-auto py-12 md:py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <div class="lg:col-span-1">
        <a href="/" class="text-2xl font-bold bg-[var(--color-logo-gradient)] bg-clip-text text-transparent">
          SpyBlue
        </a>
        <p class="mt-4 text-sm">
          Mejor Estudio WebCam de Cúcuta. Profesionalismo, seguridad y altos ingresos garantizados.
        </p>
        <div class="flex space-x-4 mt-6">
          <a href="https://www.instagram.com/spyblue.studio/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent-alt)] transition-colors">
            <Icon name="instagram" size={20} />
          </a>
          <a href="https://www.facebook.com/people/Spyblue-cucuta/100075925371638/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent-alt)] transition-colors">
            <Icon name="facebook" size={20} />
          </a>
          <a href="https://www.tiktok.com/@spyblue_studio" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent-alt)] transition-colors">
            <Icon name="tiktok" size={20} />
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Navegación</h3>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Contacto</h3>
        <ul class="space-y-3">
          <li>
            <a
              href={`https://wa.me/${WHATSAPP_NUMBER}`}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors flex items-center"
            >
              <Icon name="phone" size={16} class="mr-2" />
              +57 316 600 4712
            </a>
          </li>
          <li class="flex items-center">
            <Icon name="mail" size={16} class="mr-2" />
            info@spyblue.co
          </li>
          <li class="flex items-start">
            <Icon name="map-pin" size={16} class="mr-2 mt-0.5" />
            Cúcuta, Colombia
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Legal</h3>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-[rgba(201,154,61,0.2)] pt-8">
      <p class="text-center text-sm">
        &copy; {today.getFullYear()} SpyBlue. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>