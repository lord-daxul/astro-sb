---
const platforms = [
  { name: "Cam4", color: "#E8423F" },
  { name: "Stripchat", color: "#FF69B4", large: true },
  { name: "Chaturbate", color: "#FFA500" },
  { name: "Camsoda", color: "#00CED1" },
  { name: "ManyVids", color: "#9B59B6" },
];
---

<section id="platforms" class="section-padding overflow-hidden" style="background-color: var(--platforms-bg, var(--color-bg));">
  <div class="container-padding max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="section-title text-[var(--color-text)]">
        Transmite en
        <span class="text-[var(--color-accent)]"> Varias Plataformas</span> a la vez
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Maximiza tus ingresos transmitiendo simultáneamente en las mejores plataformas webcam del mundo
      </p>
    </div>

    <div class="rounded-xl p-8 transition-all duration-300 border border-[var(--color-border)] bg-[var(--color-card-bg)]">
      <div class="flex flex-wrap items-center justify-center gap-6 lg:gap-8">
        {platforms.map((platform) => (
          <div class="flex items-center justify-center px-6 py-4 rounded-lg transition-colors duration-300 bg-[var(--color-bg-icon)] hover:bg-[var(--color-bg-icon-hover)]">
            <span class="font-bold text-lg tracking-wide" style={{ color: platform.color }}>
              {platform.name}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
