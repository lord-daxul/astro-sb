---
import Icon from './Icon.astro';

const WHATSAPP_NUMBER = "573166004712";
const WHATSAPP_MESSAGE = "Hola, estoy interesada en conocer más sobre el estudio de modelaje webcam.";
---

<section id="intro-section" class="section-padding relative overflow-hidden" style="background-color: var(--intro-bg, var(--color-bg));">
	<div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;"></div>
	<div class="relative container-padding max-w-7xl mx-auto">
		<div class="grid lg:grid-cols-2 gap-12 items-center">
			<div>
				<h1 class="text-4xl md:text-5xl lg:text-5xl font-bold mb-6 leading-tight text-[var(--color-text)]" style="font-family: 'Montserrat', 'Poppins', ui-sans-serif, system-ui, sans-serif;">
					Mejor Estudio WebCam <br /><span class="inline-block px-3 py-1 font-bold text-white" style="background-color: #00c7b1;">Latam</span>
				</h1>

				<p class="text-lg mb-8 leading-relaxed text-[var(--color-text-muted)]">
					Triunfa Trabajando Como Modelo en <strong>EL Mejor Estudio WebCam de Cúcuta</strong>, Te Brindamos las Herramientas Para Que Puedas Incrementar tus ingresos y tu calidad de vida.
				</p>

				<a
					href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-white text-lg transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
					style="background: linear-gradient(135deg, #6a1b9a, #e91e63);"
				>
					Contactar
					<Icon name="arrow-right" size={20} />
				</a>

				<div class="flex items-center gap-8 mt-12 pt-8 border-t border-[var(--color-border)]">
					<div class="text-center">
						<div class="text-3xl md:text-4xl font-bold text-[var(--color-text)]">200<span class="text-xl">+</span></div>
						<p class="text-sm mt-1 text-[var(--color-text-dim)]">Modelos</p>
					</div>
					<div class="w-px h-12 bg-[var(--color-border)]"></div>
					<div class="text-center">
						<div class="text-3xl md:text-4xl font-bold text-[var(--color-text)]">4<span class="text-xl">+</span></div>
						<p class="text-sm mt-1 text-[var(--color-text-dim)]">Sedes</p>
					</div>
					<div class="w-px h-12 bg-[var(--color-border)]"></div>
					<div class="text-center">
						<div class="text-3xl md:text-4xl font-bold text-[var(--color-text)]">100<span class="text-xl">+</span></div>
						<p class="text-sm mt-1 text-[var(--color-text-dim)]">Escenarios</p>
					</div>
				</div>
			</div>

			<div class="rounded-2xl overflow-hidden" style="border: 2px solid #a0e9e4; background-color: #0a0f1f;">
				<div class="aspect-video flex items-center justify-center p-8">
					<img
						src="/mejor-studio-webcam-cucuta.webp"
						alt="SpyBlue Studio - Best Latam Studio"
						class="w-full h-full object-cover"
					/>
				</div>
			</div>
		</div>
	</div>
</section>
