---
import Icon from './Icon.astro';

const benefits = [
  {
    icon: "trending-up",
    title: "Pagos Puntuales",
    description: "Puntualidad y seguridad en tus pagos quincenales, en Spyblue puedes llegar a obtener ingresos que nunca pensaste.",
    image: "/pagos-puntuales.webp",
    features: ["Pagos quincenales", "Seguridad garantizada", "Altos ingresos"]
  },
  {
    icon: "clock",
    title: "Horarios Flexibles",
    description: "Disponemos de 3 turnos en horarios 24 / 7, Tu escoges el que más te convenga te esperamos en nuestros estudios en la ciudad de Cúcuta.",
    image: "/horarios-flexibles.webp",
    features: ["3 turnos disponibles", "24/7", "Elige tu horario"]
  },
  {
    icon: "shield",
    title: "Tecnología de Punta",
    description: "Disponemos de equipos de ultima generación, somos referentes a nivel latinoamericano, en tecnología e innovación.",
    image: "/tecnologia-de-punta.webp",
    features: ["Equipos de última generación", "Referentes latam", "Innovación constante"]
  },
  {
    icon: "eye",
    title: "Discreción Total",
    description: "En Nuestro estudio WEBCAM SpyBlue. Nos preocupamos por tu privacidad y tu seguridad con bloqueo de los países que elijas.",
    image: "/discrecion-total.webp",
    features: ["Bloqueo de países", "Privacidad total", "Seguridad garantizada"]
  }
];

const { background = '#0b1020', onPink = false } = Astro.props;

const titleColor = onPink ? 'var(--gold)' : 'white';
const textColor = onPink ? 'var(--brown-muted)' : 'rgba(255,255,255,0.7)';
const iconBg = onPink ? 'var(--rose-bg)' : 'rgba(255,255,255,0.05)';
const iconBorder = onPink ? 'var(--gold)' : 'rgba(41,121,255,0.3)';
const iconColor = onPink ? 'var(--gold)' : '#22d3ee';
const bulletColor = onPink ? 'var(--gold)' : '#22d3ee';
---

<section id="beneficios" class="section-padding overflow-hidden" style={`background-color: ${background};`}>
  <div class="container-padding max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="section-title" style={`color: ${onPink ? 'var(--brown-dark)' : 'white'};`}>
        Beneficios de trabajar con
        <span class="accent-text" style="color: var(--gold);"> SpyBlue</span>
      </h2>
      <p class="text-lg" style={`color: ${onPink ? 'var(--brown-muted)' : 'rgba(255,255,255,0.7)'};`} class="max-w-2xl mx-auto">
        Descubre por qué somos el mejor estudio webcam de Cúcuta y Latinoamérica
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {benefits.map((benefit, index) => (
        <div class="transition-all duration-300 group" style={`background-color: ${onPink ? 'white' : 'transparent'}; border: 1px solid ${onPink ? '#E8E4DE' : 'rgba(41,121,255,0.3)'}; border-radius: 1rem; padding: 2rem;`}>
          <div class="grid md:grid-cols-2 gap-6 items-center">
            <div class={index % 2 === 0 ? 'md:order-1' : 'md:order-2'}>
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: ${onPink ? 'var(--rose-bg)' : 'rgba(255,255,255,0.05)'}; border: 1px solid ${onPink ? 'var(--gold)' : 'rgba(41,121,255,0.3)'};`}>
                  <Icon name={benefit.icon} size={24} style={`color: ${onPink ? 'var(--gold)' : '#22d3ee'};`} />
                </div>
                <h3 class="text-xl font-bold" style={`color: ${onPink ? 'var(--gold)' : 'white'};`}>{benefit.title}</h3>
              </div>

              <p class="leading-relaxed mb-6" style={`color: ${onPink ? 'var(--brown-muted)' : 'rgba(255,255,255,0.7)'};`}>
                {benefit.description}
              </p>

              <ul class="space-y-2">
                {benefit.features.map((feature) => (
                  <li class="flex items-center text-sm" style={`color: ${onPink ? 'var(--brown-muted)' : 'rgba(255,255,255,0.7)'};`}>
                    <div class="w-1.5 h-1.5 rounded-full mr-3" style={`background-color: ${onPink ? 'var(--gold)' : '#22d3ee'};`}></div>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>

            <div class={index % 2 === 0 ? 'md:order-2' : 'md:order-1'}>
              <div class="relative overflow-hidden rounded-xl">
                <img
                  src={benefit.image}
                  alt={benefit.title}
                  class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-transparent to-transparent" style={`background: ${onPink ? 'linear-gradient(to top, rgba(252,228,236,0.5), transparent)' : 'linear-gradient(to top, rgba(11,16,32,0.5), transparent)'};`}></div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>