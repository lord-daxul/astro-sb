---
const YOUTUBE_ID = "iNv6drLzm28";
---

<section id="hero-video" class="relative w-full h-screen overflow-hidden" style="background: linear-gradient(180deg, #071C42, #0A2C63, #103A83);">
	<div class="absolute inset-0 w-full h-full">
		<iframe
			src={`https://www.youtube.com/embed/${YOUTUBE_ID}?autoplay=1&mute=1&loop=1&playlist=${YOUTUBE_ID}&controls=0&modestbranding=1&showinfo=0&rel=0&iv_load_policy=3`}
			class="absolute top-1/2 left-1/2 w-[300%] h-[300%] -translate-x-1/2 -translate-y-1/2 pointer-events-none"
			style="transform: translate(-50%, -50%) scale(1.5);"
			allow="autoplay; encrypted-media"
			title="SpyBlue Studio"
		></iframe>
	</div>
	<div class="absolute inset-0" style="background-color: rgba(0,0,0,0.77);"></div>
	<div class="absolute inset-0 flex items-center justify-center">
		<img
			src="/spyblue-cucuta-768x347 claro.webp"
			alt="SpyBlue Studio Cúcuta"
			class="max-w-[90%] md:max-w-[600px] lg:max-w-[768px] h-auto"
		/>
	</div>
</section>
