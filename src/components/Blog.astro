---
import Icon from './Icon.astro';

export interface Props {
  posts?: Array<{
    id: number;
    date: string;
    title: { rendered: string };
    excerpt: { rendered: string };
    slug: string;
    _embedded?: {
      "wp:featuredmedia"?: Array<{
        source_url: string;
        alt_text: string;
      }>;
    };
  }>;
}

const { posts = [] } = Astro.props;

function getFeaturedImage(post: any): string | null {
  return post._embedded?.["wp:featuredmedia"]?.[0]?.source_url || null;
}

function getFeaturedImageAlt(post: any): string {
  return post._embedded?.["wp:featuredmedia"]?.[0]?.alt_text || "";
}
---

<section id="blog" class="section-padding bg-[#0b1020]">
  <div class="container-padding max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white/5 border border-[#2979FF]/30 mb-4">
        <Icon name="book-open" size={24} class="text-cyan-400" />
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Noticias y Blog
      </h2>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        Consejos, noticias y actualizaciones sobre la industria webcam
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => {
        const featuredImage = getFeaturedImage(post);
        const featuredAlt = getFeaturedImageAlt(post);
        const formatDate = (dateString: string) => {
          return new Date(dateString).toLocaleDateString("es-CO", {
            year: "numeric", month: "long", day: "numeric",
          });
        };
        return (
          <article class="card-dark overflow-hidden group">
            {featuredImage && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={featuredImage}
                  alt={featuredAlt}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex items-center text-sm text-white/60 mb-3">
                <Icon name="calendar" size={16} class="mr-1 text-cyan-400" />
                {formatDate(post.date)}
              </div>
              <h3 class="text-lg font-bold text-white mb-3 line-clamp-2 group-hover:text-cyan-400 transition-colors">
                <a href={`/blog/${post.slug}`}>
                  {post.title.rendered}
                </a>
              </h3>
              <div
                class="text-white/70 text-sm mb-4 line-clamp-3"
                set:html={post.excerpt.rendered}
              />
              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center text-cyan-400 font-medium hover:text-cyan-300"
              >
                Seguir Leyendo
                <Icon name="arrow-right" size={16} class="ml-1" />
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
