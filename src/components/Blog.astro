---
import Icon from './Icon.astro';

export interface Props {
  posts?: Array<{
    id: number;
    date: string;
    title: { rendered: string };
    excerpt: { rendered: string };
    slug: string;
    _embedded?: {
      "wp:featuredmedia"?: Array<{
        source_url: string;
        alt_text: string;
      }>;
    };
  }>;
  limit?: number;
  background?: string;
}

const { posts = [], limit, background = '#0b1020' } = Astro.props;
const displayPosts = limit ? posts.slice(0, limit) : posts;
const isWhite = background === 'white' || background === '#ffffff' || background === '#fff';
const titleColor = isWhite ? 'var(--brown-dark)' : 'white';
const textColor = isWhite ? 'var(--brown-muted)' : 'rgba(255,255,255,0.7)';
const iconBg = isWhite ? 'var(--rose-bg)' : 'rgba(255,255,255,0.05)';
const iconColor = isWhite ? 'var(--gold)' : '#22d3ee';
const linkColor = isWhite ? 'var(--gold)' : '#22d3ee';
const linkHover = isWhite ? 'var(--gold)' : '#22d3ee';
const cardBg = isWhite ? 'white' : 'transparent';
const cardBorder = isWhite ? '#E8E4DE' : 'rgba(41,121,255,0.3)';

function getFeaturedImage(post: any): string | null {
  return post._embedded?.["wp:featuredmedia"]?.[0]?.source_url || null;
}

function getFeaturedImageAlt(post: any): string {
  return post._embedded?.["wp:featuredmedia"]?.[0]?.alt_text || "";
}
---

<section id="blog" class="section-padding" style={`background-color: ${background};`}>
  <div class="container-padding max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-4" style={`background-color: ${isWhite ? 'var(--rose-bg)' : 'rgba(255,255,255,0.05)'}; border: 1px solid ${isWhite ? 'var(--gold)' : 'rgba(41,121,255,0.3)'};`}>
        <Icon name="book-open" size={24} style={`color: ${isWhite ? 'var(--gold)' : '#22d3ee'};`} />
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style={`color: ${isWhite ? 'var(--brown-dark)' : 'white'};`}>
        Noticias y Blog
      </h2>
      <p class="text-lg" style={`color: ${isWhite ? 'var(--brown-muted)' : 'rgba(255,255,255,0.7)'};`} class="max-w-2xl mx-auto">
        Consejos, noticias y actualizaciones sobre la industria webcam
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {displayPosts.map((post) => {
        const featuredImage = getFeaturedImage(post);
        const featuredAlt = getFeaturedImageAlt(post);
        const formatDate = (dateString: string) => {
          return new Date(dateString).toLocaleDateString("es-CO", {
            year: "numeric", month: "long", day: "numeric",
          });
        };
        return (
          <article class="overflow-hidden group transition-all duration-300" style={`background-color: ${isWhite ? 'white' : 'transparent'}; border: 1px solid ${isWhite ? '#E8E4DE' : 'rgba(41,121,255,0.3)'}; border-radius: 1rem;`}>
            {featuredImage && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={featuredImage}
                  alt={featuredAlt}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex items-center text-sm mb-3" style={`color: ${isWhite ? 'var(--brown-muted)' : 'rgba(255,255,255,0.6)'};`}>
                <Icon name="calendar" size={16} style={`color: ${isWhite ? 'var(--gold)' : '#22d3ee'};`} class="mr-1" />
                {formatDate(post.date)}
              </div>
              <h3 class="text-lg font-bold mb-3 line-clamp-2 transition-colors" style={`color: ${isWhite ? 'var(--brown-dark)' : 'white'};`}>
                <a href={`/blog/${post.slug}`} style={`color: inherit;`}>
                  {post.title.rendered}
                </a>
              </h3>
              <div class="text-sm mb-4 line-clamp-3" style={`color: ${isWhite ? 'var(--brown-muted)' : 'rgba(255,255,255,0.7)'};`} set:html={post.excerpt.rendered} />
              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center font-medium transition-colors"
                style={`color: ${isWhite ? 'var(--gold)' : '#22d3ee'};`}
              >
                Seguir Leyendo
                <Icon name="arrow-right" size={16} class="ml-1" style={`color: ${isWhite ? 'var(--gold)' : '#22d3ee'};`} />
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
