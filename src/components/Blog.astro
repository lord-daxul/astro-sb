---
import Icon from './Icon.astro';

export interface Props {
  posts?: Array<{
    id: number;
    date: string;
    title: { rendered: string };
    excerpt: { rendered: string };
    slug: string;
    _embedded?: {
      "wp:featuredmedia"?: Array<{
        source_url: string;
        alt_text: string;
      }>;
    };
  }>;
  limit?: number;
}

const { posts = [], limit } = Astro.props;
const displayPosts = limit ? posts.slice(0, limit) : posts;

function getFeaturedImage(post: any): string | null {
  return post._embedded?.["wp:featuredmedia"]?.[0]?.source_url || null;
}

function getFeaturedImageAlt(post: any): string {
  return post._embedded?.["wp:featuredmedia"]?.[0]?.alt_text || "";
}
---

<section id="blog" class="section-padding" style="background-color: var(--blog-bg, var(--color-bg));">
  <div class="container-padding max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-4 bg-[var(--color-bg-icon)] border border-[var(--color-border-accent)]">
        <Icon name="book-open" size={24} class="text-[var(--color-accent)]" />
      </div>
      <h2 class="section-title text-[var(--color-text)]">
        Noticias y Blog
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Consejos, noticias y actualizaciones sobre la industria webcam
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {displayPosts.map((post) => {
        const featuredImage = getFeaturedImage(post);
        const featuredAlt = getFeaturedImageAlt(post);
        const formatDate = (dateString: string) => {
          return new Date(dateString).toLocaleDateString("es-CO", {
            year: "numeric", month: "long", day: "numeric",
          });
        };
        return (
          <article class="card-dark overflow-hidden group transition-all duration-300 rounded-xl">
            {featuredImage && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={featuredImage}
                  alt={featuredAlt}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex items-center text-sm mb-3 text-[var(--color-text-dim)]">
                <Icon name="calendar" size={16} class="mr-1 text-[var(--color-accent)]" />
                {formatDate(post.date)}
              </div>
              <h3 class="text-lg font-bold mb-3 line-clamp-2 transition-colors text-[var(--color-text)]">
                <a href={`/blog/${post.slug}`} class="text-inherit hover:text-[var(--color-accent)]">
                  {post.title.rendered}
                </a>
              </h3>
              <div class="text-sm mb-4 line-clamp-3 text-[var(--color-text-muted)]" set:html={post.excerpt.rendered} />
              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center font-medium transition-colors text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
              >
                Seguir Leyendo
                <Icon name="arrow-right" size={16} class="ml-1 text-[var(--color-accent)]" />
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
