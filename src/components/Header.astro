---
import ThemeToggle from './ThemeToggle.astro';
import Icon from './Icon.astro';

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/spyblue-cucuta" },
  { label: "Instalaciones", href: "/instalaciones-spyblue" },
  { label: "Trabajo WebCam", href: "/trabajo-webcam-en-cucuta" },
  { label: "FAQ", href: "/faq" },
  { label: "Contacto", href: "/modelo-webcam-en-cucuta" },
  { label: "Blog", href: "/blog-webcam" },
];

const WHATSAPP_NUMBER = "573166004712";
const WHATSAPP_MESSAGE = "Hola, estoy interesada en conocer más sobre el estudio de modelaje webcam.";
---

<header class="site-header sticky top-0 z-50 bg-[var(--color-bg)]/95 backdrop-blur-sm border-b border-[var(--color-border)] transition-all duration-300">
  <div class="container-padding max-w-7xl mx-auto">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center space-x-2">
        <span class="logo-wrapper">
          <img src="/spyblue light.webp" alt="SpyBlue" class="logo-light h-8 w-auto" />
          <img src="/spyblue dark.webp" alt="SpyBlue" class="logo-dark h-8 w-auto" />
        </span>
      </a>

      <nav class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          <a href={item.href} class="text-[var(--header-text)] hover:text-[var(--header-text-hover)] font-medium transition-colors">
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:flex items-center space-x-4">
        <ThemeToggle />
        <a
          href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-[var(--header-cta-gradient)] text-[var(--header-cta-text)] transition-all duration-300 hover:shadow-lg hover:shadow-[var(--header-text-hover)]/30 hover:-translate-y-0.5"
        >
          <Icon name="whatsapp" size={16} />
          WhatsApp
        </a>
      </div>

      <div class="md:hidden flex items-center space-x-2">
        <ThemeToggle />
        <button id="menu-toggle" class="p-2 text-[var(--header-text)]" aria-label="Toggle menu">
          <Icon name="menu" class="w-6 h-6" />
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="md:hidden hidden py-4 border-t border-[var(--color-border)]">
      <nav class="flex flex-col space-y-4">
        {navItems.map((item) => (
          <a href={item.href} class="text-[var(--header-text)] hover:text-[var(--header-text-hover)] font-medium px-2 py-1 mobile-link">
            {item.label}
          </a>
        ))}
        <a
          href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-[var(--header-cta-gradient)] text-[var(--header-cta-text)] transition-all duration-300 hover:shadow-lg hover:shadow-[var(--header-text-hover)]/30 hover:-translate-y-0.5 mx-2"
        >
          <Icon name="whatsapp" size={16} />
          WhatsApp
        </a>
        </nav>
      </div>

<style>
  .logo-wrapper { display: flex; }
  .logo-light { display: block; }
  .logo-dark { display: none; }
  html.dark .logo-light { display: none; }
  html.dark .logo-dark { display: block; }
</style>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  let isOpen = false;

  menuToggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    mobileMenu?.classList.toggle('hidden', !isOpen);
    menuToggle.innerHTML = isOpen
      ? '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
      : '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="18" x2="20" y2="18"/></svg>';
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      isOpen = false;
      mobileMenu?.classList.add('hidden');
      menuToggle.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="18" x2="20" y2="18"/></svg>';
    });
  });
</script>